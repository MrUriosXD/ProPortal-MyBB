<?xml version="1.0" encoding="UTF-8"?>
<theme name="MyBB Master Style" version="1400">
	<templates>
			<template name="pro_blog" version="1400"><![CDATA[<html>
<head>
<title>{$mybb->settings['bbname']}</title>
{$headerinclude}
</head>
<body>
{$header}
<table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tr>
<td valign="top" width="{$problog->settings['leftcolwidth']}" style="padding-right:{$problog->settings['verticalspace']}px">
{$leftblocks}
</td>
<td valign="top">
{$centerblocks}
</td>
<td valign="top" width="{$problog->settings['rightcolwidth']}" style="padding-left:{$problog->settings['verticalspace']}px">
{$rightblocks}
</td>
</tr>
</table>
<table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tr>
<td align="center" width="100%" class="smalltext"><a href="http://www.promybb.com/" target="_blank">Pro Blog 1.0</a> &copy; 2010 <a href="http://atopal.com/" target="_blank">Adnan TOPAL</a></td>
</tr>
</table>
{$footer}
</body>
</html>]]></template>
			<template name="pro_blog_announcement" version="1400"><![CDATA[<table cellspacing="{$theme['borderwidth']}" cellpadding="{$theme['tablespace']}" class="tborder">
<tr>
<td class="thead"><strong>{$icon} <a href="{$announcement['threadlink']}">{$announcement['subject']}</a></strong></td>
</tr>
<tr>
<td class="trow2" align="right" valign="middle">
<span style="float: left;">{$avatar}</span>
<span class="smalltext">{$lang->posted_by} {$profilelink} - {$anndate} {$anntime}<br />{$views} {$numcomments} {$likes}</span>
</td>
</tr>
<tr>
<td class="trow1">
<table border="0" cellpadding="{$theme['tablespace']}" width="100%">
	<tr>
		<td class="trow1" style="border: 0px;">
			<div style="margin: -2px 0;">
				{$message}
			</div>
		</td>
	</tr>
</table>
</td>
</tr>
<tr>
<td class="trow2" align="right" valign="middle">
<span class="smalltext">
{$like_btn}
</span>
</td>
</tr>
</table>
<br />]]></template>
			<template name="pro_blog_block" version="1400"><![CDATA[<div style="padding-bottom:{$problog->settings['horizontalspace']}px;">
<table border="0" cellspacing="{$theme['borderwidth']}" cellpadding="{$theme['tablespace']}" class="tborder">
<tr>
<td class="thead"><div class="expcolimage"><img src="{$theme['imgdir']}/{$expcolimage}" id="block_{$result_blocks['id']}_img" class="expander" alt="{$expaltext}" title="{$expaltext}" /></div><strong>{$title}</strong></td>
</tr>
<tbody style="{$expdisplay}" id="block_{$result_blocks['id']}_e">
<tr>
<td class="trow1">
{$content}
</td>
</tr>
</tbody>
</table>
</div>]]></template>
			<template name="pro_blog_left" version="1400"><![CDATA[<html>
<head>
<title>{$mybb->settings['bbname']}</title>
{$headerinclude}
</head>
<body>
{$header}
<table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tr>
<td valign="top" width="{$problog->settings['leftcolwidth']}" style="padding-right:{$problog->settings['verticalspace']}px">
{$leftblocks}
</td>
<td valign="top">
{$centerblocks}
</td>
</tr>
</table>
<table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tr>
<td align="center" width="100%" class="smalltext"><a href="http://promybb.com/" target="_blank">Pro Blog 1.0</a> &copy; 2010 <a href="http://atopal.com/" target="_blank">DragonFever</a></td>
</tr>
</table>
{$footer}
</body>
</html>]]></template>
			<template name="pro_blog_page" version="1400"><![CDATA[<div style="padding-bottom:{$problog->settings['horizontalspace']}px;">
<table border="0" cellspacing="{$theme['borderwidth']}" cellpadding="{$theme['tablespace']}" class="tborder">
<tr>
<td class="thead"><strong>{$title}</strong></td>
</tr>
<tbody>
<tr>
<td class="trow1">
{$content}
</td>
</tr>
</tbody>
</table>
</div>]]></template>
			<template name="pro_blog_right" version="1400"><![CDATA[<html>
<head>
<title>{$mybb->settings['bbname']}</title>
{$headerinclude}
</head>
<body>
{$header}
<table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tr>
<td valign="top">
{$centerblocks}
</td>
<td valign="top" width="{$problog->settings['rightcolwidth']}" style="padding-left:{$problog->settings['verticalspace']}px">
{$rightblocks}
</td>
</tr>
</table>
<table width="100%" cellspacing="0" cellpadding="0" border="0" align="center">
<tr>
<td align="center" width="100%" class="smalltext"><a href="http://promybb.com/" target="_blank">Pro Blog 1.0</a> &copy; 2010 <a href="http://atopal.com/" target="_blank">DragonFever</a></td>
</tr>
</table>
{$footer}
</body>
</html>]]></template>
			<template name="pro_blog_comment_bit" version="1400"><![CDATA[<div class="tborder" style="margin-bottom: 10px; padding: 10px;">
<strong>{$comment['username']}</strong> - <span class="smalltext">{$comment['date']}</span>
<div style="margin-top: 5px;">{$comment['content']}</div>
</div>]]></template>
			<template name="pro_blog_quick_reply" version="1400"><![CDATA[<div style="margin-top: 20px;">
<form method="post" action="blog.php?action=do_comment">
<input type="hidden" name="my_post_key" value="{$mybb->post_code}" />
<input type="hidden" name="pid" value="{$id}" />
<table border="0" cellspacing="{$theme['borderwidth']}" cellpadding="{$theme['tablespace']}" class="tborder">
<tr><td class="thead"><strong>Post a Comment</strong></td></tr>
<tr><td class="trow1"><textarea name="message" rows="5" style="width: 95%"></textarea></td></tr>
<tr><td class="trow2" align="center"><input type="submit" class="button" value="Submit Comment" /></td></tr>
</table>
</form>
</div>]]></template>
			<template name="pro_blog_report" version="1400"><![CDATA[<div style="margin-top: 20px;">
<form method="post" action="blog.php?action=do_report">
<input type="hidden" name="my_post_key" value="{$mybb->post_code}" />
<input type="hidden" name="id" value="{$id}" />
<input type="hidden" name="type" value="{$type}" />
<table border="0" cellspacing="{$theme['borderwidth']}" cellpadding="{$theme['tablespace']}" class="tborder">
<tr><td class="thead"><strong>Report Item</strong></td></tr>
<tr><td class="trow1">Please enter the reason for reporting this item:</td></tr>
<tr><td class="trow1"><textarea name="reason" rows="5" style="width: 95%"></textarea></td></tr>
<tr><td class="trow2" align="center"><input type="submit" class="button" value="Send Report" /></td></tr>
</table>
</form>
</div>]]></template>
			<template name="pro_blog_search" version="1400"><![CDATA[<table border="0" cellspacing="{$theme['borderwidth']}" cellpadding="{$theme['tablespace']}" class="tborder">
<tr><td class="thead"><strong>{$lang->search_results}</strong></td></tr>
<tr><td class="trow1">{$search_results}</td></tr>
</table>]]></template>
	</templates>
</theme>
